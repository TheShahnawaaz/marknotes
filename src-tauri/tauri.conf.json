{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkNotes",
  "version": "1.0.6",
  "identifier": "com.marknotes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MarkNotes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5QzVFRUZEM0U3RkJDQzEKUldUQnZIOCsvZTdGaVNON2JIMmIyNXFEYWV1VU9HT2pNRVhyOS9mNUNZZ3c3ZC9rdFdORWdDc28K",
      "endpoints": [
        "https://github.com/TheShahnawaaz/marknotes/releases/latest/download/latest.json"
      ]
    }
  }
}
